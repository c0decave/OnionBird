FROM docker.io/alpine:3.20

# B-081: pin Tor to a specific Alpine package version so the test
# suite's SOCKS5-RESOLVE behavioural assertions are replayable
# across Alpine point releases. Bump explicitly when upgrading;
# the unpinned form would silently pull a new minor.
# Note: if the pinned version is no longer in Alpine's repo (purge
# after EOL), the build will fail loudly here — that's the
# intended failure mode (forces an explicit version review).
ARG TOR_PKG_VERSION=0.4.9.8-r0
RUN apk add --no-cache "tor=${TOR_PKG_VERSION}" bash su-exec

RUN mkdir -p /var/lib/tor/hs_smtp \
    && chown -R tor:tor /var/lib/tor \
    && chmod 700 /var/lib/tor /var/lib/tor/hs_smtp

COPY torrc /etc/tor/torrc
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 9050 9051

ENTRYPOINT ["/entrypoint.sh"]
