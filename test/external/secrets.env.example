# Copy to secrets.env, fill in, then `set -a; source secrets.env; set +a`
# secrets.env is gitignored. NEVER commit real credentials.

# === Host Tor SOCKS endpoint ===
T0R_SOCKS_HOST=127.0.0.1
T0R_SOCKS_PORT=9050             # 9150 for Tor Browser

# === Marionette on host TB ===
T0R_TB_HOST=127.0.0.1
T0R_TB_PORT=2828

# === Provider: DISROOT ===
T0R_DISROOT_USER=throwaway-disroot
T0R_DISROOT_PASS=
T0R_DISROOT_EMAIL=throwaway-disroot@disroot.org
T0R_DISROOT_SMTP_ONION=disrootqdpwd5jpufcoo676miq6r5lehcwm6byx4bdj7p77dxitgfqd.onion
T0R_DISROOT_SMTP_PORT=25
T0R_DISROOT_IMAP_ONION=disrootqdpwd5jpufcoo676miq6r5lehcwm6byx4bdj7p77dxitgfqd.onion
T0R_DISROOT_IMAP_PORT=143       # plain over Tor; or 993 with SSL

# === Provider: RISEUP ===
T0R_RISEUP_USER=
T0R_RISEUP_PASS=
T0R_RISEUP_EMAIL=
T0R_RISEUP_SMTP_HOST=mail.riseup.net
T0R_RISEUP_SMTP_PORT=587
T0R_RISEUP_IMAP_HOST=mail.riseup.net
T0R_RISEUP_IMAP_PORT=993

# === Provider: OWN self-hosted ===
T0R_OWN_USER=
T0R_OWN_PASS=
T0R_OWN_EMAIL=
T0R_OWN_SMTP_HOST=
T0R_OWN_SMTP_PORT=
T0R_OWN_IMAP_HOST=
T0R_OWN_IMAP_PORT=

# === Provider: POSTEO ===
T0R_POSTEO_USER=
T0R_POSTEO_PASS=
T0R_POSTEO_EMAIL=
T0R_POSTEO_SMTP_HOST=posteo.de
T0R_POSTEO_SMTP_PORT=587
T0R_POSTEO_IMAP_HOST=posteo.de
T0R_POSTEO_IMAP_PORT=993

# === Second receiving address (for cross-provider tests) ===
# Optional: a different account/provider for end-to-end delivery checks
T0R_RECV_EMAIL=
T0R_RECV_USER=
T0R_RECV_PASS=
T0R_RECV_IMAP_HOST=
T0R_RECV_IMAP_PORT=

# === Test mode flags ===
T0R_TEST_PROVIDER=DISROOT       # which provider to run
T0R_TEST_USE_ONION=true         # prefer onion endpoints when available
T0R_TEST_WAIT_DELIVERY=30       # seconds to wait for IMAP arrival
